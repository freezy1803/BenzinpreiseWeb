# Web server port
PORT=3000

# MySQL database
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# External live prices API (from http://einstein.freezy.xyz:6976/docs)
# Base URL without trailing slash
PRICES_API_URL=http://einstein.freezy.xyz:6976
# Adjust path based on actual API docs (e.g. /prices, /fuel/current, /api/prices)
PRICES_API_PATH=/prices
# Query param names used by the external API
PRICES_API_PARAM_ZIP=zip_code
PRICES_API_PARAM_RADIUS=radius_km
